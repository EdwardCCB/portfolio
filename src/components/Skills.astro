---
import { skills, techIcons } from "../data/portfolio";
import SkillBars from "./react/SkillBars.tsx";
---

<section id="skills" class="section skills">
  <div
    class="ambient-glow"
    style="width:500px;height:500px;background:#3b82f6;bottom:-20%;left:-10%;opacity:0.07;filter:blur(80px);"
  >
  </div>
  <div class="container">
    <div class="section-heading reveal">
      <div class="section-label">02. Stack Tecnológico</div>
      <h2 class="section-title">
        Mis <span class="gradient-text">Skills</span>
      </h2>
      <div class="divider"></div>
      <p class="section-subtitle">Tecnologías con las que construyo.</p>
    </div>

    <!-- Tech icon grid -->
    <div class="tech-grid reveal">
      {
        techIcons.map((tech) => (
          <div class="tech-icon-card glass-card">
            <span class="tech-emoji">{tech.icon}</span>
            <span class="tech-name">{tech.name}</span>
          </div>
        ))
      }
    </div>

    <!-- Skill bars (React island) -->
    <div class="skills__bars reveal" style="transition-delay:0.2s">
      <SkillBars skills={skills} client:visible />
    </div>
  </div>
</section>

<style>
  .skills {
    position: relative;
    overflow: hidden;
    background: linear-gradient(
      180deg,
      var(--bg-secondary) 0%,
      var(--bg-primary) 100%
    );
  }

  .tech-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
    gap: 0.85rem;
    margin-bottom: 3.5rem;
  }

  .tech-icon-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1.25rem 0.75rem;
    cursor: default;
  }

  .tech-emoji {
    font-size: 1.8rem;
    line-height: 1;
    transition: transform var(--transition-base);
  }

  .tech-icon-card:hover .tech-emoji {
    transform: scale(1.3);
  }

  .tech-name {
    font-size: 0.72rem;
    font-weight: 600;
    color: var(--text-secondary);
    text-align: center;
    font-family: var(--font-mono);
  }

  .skills__bars {
    max-width: 820px;
    margin: 0 auto;
  }
</style>
