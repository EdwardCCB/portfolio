---
import { personal } from "../data/portfolio";
---

<header class="navbar" id="navbar">
  <div class="container navbar__inner">
    <a href="#hero" class="navbar__logo">
      <span class="logo-bracket">&lt;</span>
      <span class="logo-name">Eduardo</span>
      <span class="logo-bracket">/&gt;</span>
    </a>

    <nav class="navbar__links">
      <a href="#about" class="nav-link">Sobre mí</a>
      <a href="#skills" class="nav-link">Skills</a>
      <a href="#projects" class="nav-link">Proyectos</a>
      <a href="#experience" class="nav-link">Experiencia</a>
      <a href="#contact" class="nav-link">Contacto</a>
    </nav>

    <a
      href="/portfolio/CV_EduardoMarino_EN.pdf"
      target="_blank"
      rel="noopener noreferrer"
      class="btn btn-primary navbar__cta">Resume CV</a
    >

    <button class="navbar__hamburger" id="hamburger" aria-label="Menu">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    padding: 1rem 0;
    transition:
      background var(--transition-base),
      box-shadow var(--transition-base);
  }

  .navbar.scrolled {
    background: rgba(5, 5, 16, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    box-shadow: 0 1px 0 rgba(139, 92, 246, 0.15);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .navbar__logo {
    font-size: 1.3rem;
    font-weight: 800;
    font-family: var(--font-mono);
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .logo-bracket {
    color: var(--accent-violet);
  }

  .logo-name {
    color: var(--text-primary);
    margin: 0 1px;
  }

  .navbar__links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-link {
    color: var(--text-secondary);
    font-size: 0.9rem;
    font-weight: 500;
    padding: 0.4rem 0.8rem;
    border-radius: 0.5rem;
    transition:
      color var(--transition-fast),
      background var(--transition-fast);
    text-decoration: none;
  }

  .nav-link:hover {
    color: var(--text-primary);
    background: rgba(139, 92, 246, 0.1);
  }

  .navbar__cta {
    padding: 0.5rem 1.2rem;
    font-size: 0.875rem;
  }

  .navbar__hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.25rem;
  }

  .navbar__hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--text-primary);
    border-radius: 2px;
    transition: all var(--transition-base);
  }

  @media (max-width: 768px) {
    .navbar__links {
      display: none;
    }
    .navbar__cta {
      display: none;
    }
    .navbar__hamburger {
      display: flex;
    }
  }
</style>

<script>
  const navbar = document.getElementById("navbar");
  window.addEventListener("scroll", () => {
    if (window.scrollY > 20) {
      navbar?.classList.add("scrolled");
    } else {
      navbar?.classList.remove("scrolled");
    }
  });
</script>
